# 부동산 투자 자문 시스템 환경 변수 예시
# 이 파일을 복사해서 .env 로 저장하고 실제 키를 채우세요.
# .env 는 절대 git 에 커밋하지 않습니다.

# ── LLM (필수) ──
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ── 부동산 데이터 API (Stage 1) ──
# DATA_GO_KR_API_KEY=xxxxxxxxxxxx  # 공공데이터포털 인증키

# ── RAG (Stage 2) ──
# PINECONE_API_KEY=xxxxxxxxxxxx
# PINECONE_ENVIRONMENT=us-east-1

# ── 공통 설정 ──
LLM_MODEL=claude-sonnet-4-6
